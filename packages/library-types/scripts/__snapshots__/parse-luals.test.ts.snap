    {
      "brief": "",
      "fields": [
        {
          "doc": "The amount of input given by the user. This is usually 1 for buttons and 0-1 for analogue inputs. This is not present for mouse movement.",
          "isOptional": false,
          "name": "value",
          "types": [
            "number",
          ],
        },
        {
          "doc": "If the input was pressed this frame. This is not present for mouse movement.",
          "isOptional": false,
          "name": "pressed",
          "types": [
            "boolean",
          ],
        },
        {
          "doc": "If the input was released this frame. This is not present for mouse movement.",
          "isOptional": false,
          "name": "released",
          "types": [
            "boolean",
          ],
        },
        {
          "doc": "If the input was repeated this frame. This is similar to how a key on a keyboard is repeated when you hold it down. This is not present for mouse movement.",
          "isOptional": false,
          "name": "repeated",
          "types": [
            "boolean",
          ],
        },
        {
