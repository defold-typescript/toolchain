    {
      "brief": "The component that handles a rich text display, allows to custom color, size, font, etc. of the parts of the text",
      "extends": "druid.component",
      "fields": [
        {
          "doc": "The root text node of the rich text",
          "isOptional": false,
          "name": "root",
          "types": [
            "node",
          ],
        },
        {
          "doc": "The text prefab node",
          "isOptional": false,
          "name": "text_prefab",
          "types": [
            "node",
          ],
        },
        {
          "doc": "The last value of the rich text",
          "isOptional": false,
          "name": "_last_value",
          "types": [
            "string",
          ],
          "visibility": "private",
        },
        {
          "doc": "The settings of the rich text",
          "isOptional": false,
          "name": "_settings",
          "types": [
            "table",
          ],
          "visibility": "private",
        },
        {
          "doc": "The split to characters flag",
          "isOptional": false,
          "name": "_split_to_characters",
          "types": [
            "boolean",
          ],
          "visibility": "private",
        },
        {
          "doc": "Anchor position when pivot is set (keeps content in place on resize)",
          "isOptional": false,
          "name": "_anchor",
          "types": [
            "vector3|nil",
          ],
          "visibility": "private",
        },
      ],
      "generics": [],
      "methods": [
        {
          "brief": "",
          "generics": [],
          "name": "init",
          "params": [
            {
              "doc": "The text node to make Rich Text",
              "isOptional": false,
              "isVararg": false,
              "name": "text_node",
              "types": [
                "node|string",
              ],
            },
            {
              "doc": "The initial text value. Default will be gui.get_text(text_node)",
              "isOptional": false,
              "isVararg": false,
              "name": "value",
              "types": [
                "string|nil",
              ],
            },
          ],
          "returns": [],
        },
        {
          "brief": "",
          "generics": [],
          "name": "on_layout_change",
          "params": [],
          "returns": [],
