            "table<hash, boolean>",
          ],
          "visibility": "private",
        },
        {
          "doc": "The release timestamp for modificators",
          "isOptional": false,
          "name": "_modificator_released_at",
          "types": [
            "table<hash, number>",
          ],
          "visibility": "private",
        },
        {
          "doc": "The node to bind the hotkey to",
          "isOptional": false,
          "name": "_node",
          "types": [
