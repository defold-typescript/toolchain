          ],
        },
        {
          "doc": "fun(self: druid.input) The event triggered when the input field is full",
          "isOptional": false,
          "name": "on_input_full",
          "types": [
            "event",
          ],
        },
        {
          "doc": "fun(self: druid.input) The event triggered when the input field is wrong",
          "isOptional": false,
          "name": "on_input_wrong",
          "types": [
            "event",
          ],
        },
        {
          "doc": "fun(self: druid.input, cursor_index: number, start_index: number, end_index: number) The event triggered when the cursor index is changed",
          "isOptional": false,
          "name": "on_select_cursor_change",
          "types": [
            "event",
          ],
        },
        {
          "doc": "The style of the input component",
          "isOptional": false,
          "name": "style",
          "types": [
            "druid.input.style",
          ],
        },
      ],
