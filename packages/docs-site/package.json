{
  "name": "@defold-typescript/docs-site",
  "version": "0.0.0",
  "description": "Static documentation site for defold-typescript, rendering the guide to HTML.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build-indexes": "bun scripts/build-search-index.ts && bun scripts/build-symbol-index.ts",
    "dev": "bun run build-indexes && vite",
    "build": "bun run build-indexes && vite build --mode client && vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@defold-typescript/types": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@orama/orama": "^3.1.18",
    "@phosphor-icons/core": "^2.1.1",
    "@shikijs/markdown-it": "^4.2.0",
    "hono": "^4.12.25",
    "honox": "^0.1.56",
    "markdown-it": "^14.2.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@hono/vite-ssg": "^0.3.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4",
    "@types/markdown-it": "^14.1.2",
    "tailwindcss": "^4",
    "vite": "^8.0.16"
  }
}
