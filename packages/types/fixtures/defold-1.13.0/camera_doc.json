    {
      "type": "CONSTANT",
      "name": "camera.ORTHO_MODE_AUTO_FIT",
      "brief": "auto-fit orthographic zoom mode",
      "description": "Computes zoom so the original display area (game.project width/height) fits inside the window\nwhile preserving aspect ratio. Equivalent to using min(window_width/width, window_height/height).\nThe result is multiplied by the user-controlled orthographic zoom.",
