{
  // Type-checks the repo-root test/ tree, which no package tsconfig covers. A
  // standard `tsconfig.json` name so editors auto-discover it; allowImporting
  // TsExtensions matches the bun-style .ts imports these tests use (e.g. the
  // scripts they exercise). Wired into the root `typecheck` script.
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["**/*.ts"]
}
