{
  "name": "defold-typescript",
  "private": true,
  "version": "0.0.0",
  "description": "TypeScript to Lua transpiling for Defold — a faster, agent-friendly successor to ts-defold.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck && tsc -p scripts/tsconfig.json && tsc -p test/tsconfig.json",
    "smoke": "bun scripts/release-smoke.ts",
    "registry-smoke": "bun scripts/registry-smoke.ts",
    "pack-proof": "bun scripts/release-pack-proof.ts",
    "example-smoke": "bun scripts/example-smoke.ts",
    "build:lldebugger": "bun scripts/build-lldebugger-zip.ts",
    "ref-doc-delta": "bun --cwd packages/types run ref-doc-delta"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "lefthook": "^2.1.9",
    "typescript": "6.0.2",
    "yaml": "^2.9.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
