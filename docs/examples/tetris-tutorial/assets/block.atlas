images {
  image: "/assets/images/block.png"
  sprite_trim_mode: SPRITE_TRIM_MODE_OFF
}
animations {
  id: "block"
  images {
    image: "/assets/images/block.png"
    sprite_trim_mode: SPRITE_TRIM_MODE_OFF
  }
  playback: PLAYBACK_NONE
  fps: 60
  flip_horizontal: 0
  flip_vertical: 0
}
margin: 0
extrude_borders: 2
inner_padding: 0
