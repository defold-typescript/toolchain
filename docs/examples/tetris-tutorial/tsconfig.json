{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@defold-typescript/types": ["../../../packages/types/src/index.ts"],
      "@defold-typescript/types/script": ["../../../packages/types/generated/kinds/script.d.ts"],
      "@defold-typescript/types/gui-script": [
        "../../../packages/types/generated/kinds/gui-script.d.ts"
      ],
      "@defold-typescript/types/timers": ["../../../packages/types/src/timers.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
